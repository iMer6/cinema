<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Бронювання: <%= session.title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: linear-gradient(135deg, #eef2f7, #e3e9f2);
            font-family: Verdana, Geneva, Tahoma, sans-serif;
        }
        .hall-container {
            background: linear-gradient(160deg, #1f2a38, #2c3e50);
            padding: 50px 40px;
            border-radius: 24px;
            margin-top: 20px;
            color: snow;
            box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        }
        .screen {
            width: 75%;
            height: 25px;
            background: linear-gradient(to bottom, white, #dfe6e9);
            margin: 0 auto 60px;
            border-radius: 12px;
            text-align: center;
            font-size: 12px;
            letter-spacing: 2px;
            color: #636e72;
            line-height: 25px;
            text-transform: uppercase;
            box-shadow: 0 8px 25px rgba(255,255,255,0.4);
        }
        .seat-row {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 5px;
        }
        .row-label {
            width: 70px;
            font-size: 13px;
            color: #95a5a6;
            text-align: right;
            margin-right: 10px;
        }
        .seat {
            width: 38px;
            height: 38px;
            margin: 4px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.25s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.25);
        }
        .available {
            background: linear-gradient(145deg, #2ecc71, #27ae60);
            color: snow;
        }
        .available:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 8px 20px rgba(46, 204, 113, 0.6);
        }
        .occupied {
            background: linear-gradient(145deg, #e74c3c, #c0392b);
            color: snow;
            cursor: not-allowed;
            opacity: 0.6;
            box-shadow: none;
        }
        .selected {
            background: linear-gradient(145deg, #f1c40f, #f39c12) !important;
            color: #2c3e50;
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(241, 196, 15, 0.6);
        }
        .legend {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 40px;
            font-size: 14px;
        }
        .legend-item {
            display: flex;
            align-items: center;
            gap: 10px;
            opacity: 0.9;
        }
        .legend .seat {
            width: 22px;
            height: 22px;
            margin: 0;
            box-shadow: none;
        }
        .card {
            border-radius: 18px;
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .btn-primary {
            border-radius: 12px;
            padding: 10px;
            font-weight: 600;
            transition: all 0.2s ease;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(13,110,253,0.4);
        }
    </style>
</head>
<body class="bg-light">
    <% if (user) { %>
    <div class="container py-5">
        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h2 class="h4"><%= session.title %></h2>
                        <hr>
                        <p><strong>Зал:</strong> <%= session.name %></p>
                        <p><strong>Дата:</strong> <%= new Date(session.date).toLocaleDateString('uk-UA') %></p>
                        <p><strong>Початок:</strong> <%= session.start_time.toString().slice(0, 5) %></p>
                        <button id="btn-buy" class="btn btn-primary w-100 mt-3" disabled>Купити квитки</button>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="hall-container shadow">
                    <div class="screen">Екран</div>
                    
                    <div class="seats-wrapper">
                        <% let currentRow = -1; 
                            seats.forEach(seat => { 
                                if (seat.row_number !== currentRow) { 
                                    if (currentRow !== -1) { %> </div> <% }
                                    currentRow = seat.row_number; 
                        %>
                            <div class="seat-row">
                                <div class="row-label">Ряд <%= currentRow %></div>
                        <% } %>
                            <button 
                                class="seat <%= seat.status %>" 
                                title="Ряд <%= seat.row_number %>, Місце <%= seat.seat_number %>"
                                data-id="<%= seat.seat_id %>"
                                <%= seat.status === 'occupied' ? 'disabled' : '' %>>
                                <%= seat.seat_number %>
                            </button>
                        <% }); %>
                        </div>
                </div>

                <div class="legend">
                    <div class="legend-item"><div class="seat available" style="width:20px; height:20px;"></div> Вільно</div>
                    <div class="legend-item"><div class="seat occupied" style="width:20px; height:20px;"></div> Зайнято</div>
                    <div class="legend-item"><div class="seat selected" style="width:20px; height:20px;"></div> Обрано</div>
                </div>
            </div>
        </div>
    </div>
    </div>
    <script>
        const selectedSeats = new Set();
        const buyBtn = document.getElementById('btn-buy');

        document.querySelectorAll('.seat.available').forEach(seat => {
            seat.addEventListener('click', () => {
                const seatId = seat.getAttribute('data-id');
                
                if (selectedSeats.has(seatId)) {
                    selectedSeats.delete(seatId);
                    seat.classList.remove('selected');
                } else {
                    selectedSeats.add(seatId);
                    seat.classList.add('selected');
                }

                buyBtn.disabled = selectedSeats.size == 0;
                buyBtn.innerText = selectedSeats.size > 0 
                    ? `Купити квитки (${selectedSeats.size})` 
                    : 'Купити квитки';
            });
        });

        buyBtn.addEventListener('click', async () => {
            if (selectedSeats.size == 0) return;

            const data = { sessionId: "<%= session.session_id %>", seatIds: Array.from(selectedSeats) };

            try {
                const response = await fetch('/booking/confirm', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                
                result.success ? window.location.href = `
                    /booking/confirmation?session=${data.sessionId}&seats=${data.seatIds.join(',')}`
                              : alert("Помилка при бронюванні. Можливо, місця вже зайняті.");

            } catch (err) { console.error("Помилка мережі:", err); }
        });
    </script>
    <% } else { %>
        <div class="text-center mt-5"><h2>Доступ заборонено</h2></div>
    <% } %>
</body>
</html>