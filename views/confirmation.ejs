<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Підтвердження квитка</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <% if (user) { %>
    <div class="container py-5">
        <div class="card shadow-lg mx-auto" style="max-width: 700px; border: none; border-radius: 15px;">
            <div class="card-header bg-dark text-white text-center py-4" style="border-radius: 15px 15px 0 0;">
                <i class="bi bi-check2-circle display-4 text-success"></i>
                <h2 class="mt-2">Ваше бронювання підтверджено!</h2>
            </div>
            
            <div class="card-body p-4">
                <div class="mb-4">
                    <h5 class="text-primary border-bottom pb-2">Фільм</h5>
                    <h3 class="fw-bold"><%= details.title %></h3>
                    <p class="text-muted"><i class="bi bi-clock"></i> Тривалість: <%= details.duration %> хв.</p>
                </div>

                <div class="row mb-4">
                    <div class="col-sm-6">
                        <h5 class="text-primary border-bottom pb-2">Дата та час</h5>
                        <p class="mb-1"><strong>Дата:</strong> <%= new Date(details.date).toLocaleDateString('uk-UA') %></p>
                        <p><strong>Початок:</strong> <%= details.start_time.slice(0,5) %></p>
                    </div>
                    <div class="col-sm-6">
                        <h5 class="text-primary border-bottom pb-2">Місця (<%= totalSeats %>)</h5>
                        <div class="d-flex flex-wrap gap-2">
                            <% seats.forEach(s => { %>
                                <span class="badge bg-secondary p-2">Ряд <%= s.row_number %>, Місце <%= s.seat_number %></span>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <div class="p-3 bg-white border rounded shadow-sm mb-4">
                    <h5 class="text-primary"><i class="bi bi-geo-alt-fill"></i> Локація</h5>
                    <p class="mb-1"><strong><%= details.cname %></strong> (<%= details.hname %>)</p>
                    <p class="text-muted mb-0">
                        <%= details.city_name %>, вул. <%= details.street %>, буд. <%= details.building %>
                    </p>
                </div>

                <div class="d-grid gap-2">
                    <button onclick="window.print()" class="btn btn-outline-dark">
                        <i class="bi bi-printer"></i> Роздрукувати квиток
                    </button>
                    <a href="/film" class="btn btn-primary btn-lg">На головну</a>
                </div>
            </div>
        </div>
    </div>
    <% } else { %>
        <div class="text-center mt-5"><h2>Доступ заборонено</h2></div>
    <% } %>
</body>
</html>