<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Сеанси за місяцями</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/statistic.css">
</head>

<body>
    <% if (user) { %>
    <div class="container-fluid">
        <% if (statistic?.length> 0) { %>
            <h2 style="margin-top: 5vh;">Кількість сеансів за місяцями</h2>
            <table class="table-responsive">
                <thead>
                    <tr>
                        <th>Місяць</th>
                        <th>Кількість сеансів</th>
                    </tr>
                </thead>
                <tbody class="data-table">
                    <% statistic.forEach(session => { %>
                        <tr>
                            <td><%= session.month %></td>
                            <td><%= session.sessions_count %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } else { %><h2>Таких сеансів немає</h2><% } %>
    </div>
    <% } else { %>
        <div class="text-center mt-5"><h2>Доступ заборонено</h2></div>
    <% } %>
</body>
</html>