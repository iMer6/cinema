<!DOCTYPE html>
<html lang="uk">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= inform.length > 0 ? inform[0].title : 'Фільм не знайдено' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/info.css">
</head>
<body>
    <div class="container">
        <% if (inform?.length > 0) { const film = inform[0]; %>
            <div class="film-card">
                <div class="film-poster-section">
                    <div class="poster-placeholder">
                        <img src="/public/posters/<%= film.film_id %>.jpg" alt="ПОСТЕР"
                             onerror="this.onerror=null; this.src='/public/posters/default.jpg'">
                    </div>
                        <button class="btn btn-light btn-action" 
                                onclick="window.location.href='/session/film/<%= film.film_id %>'">
                                ДОСТУПНІ СЕАНСИ
                        </button>
                </div>

                <div class="film-content">
                    <div class="film-header"><h1 class="film-title"><%= film.title %></h1></div>
                    
                    <div class="mt-4" style="padding-bottom: 25px;">
                        <small class="text-muted"><%= film.original_title %></small>
                    </div>
                    <div class="film-meta">
                        <%= film.release_year %> • <%= film.genres %> • <%= film.countries %> • <%= film.duration %> хв.
                    </div>
                    <div class="film-description"><%= film.description %></div>
                    <div class="rating-badge">Рейтинг: <span class="text-warning"><%= film.rating %></span> / 10</div>
                </div>
            </div>
        <% } else { %>
            <div class="text-center mt-5">
                <h1 class="display-1">404</h1>
                <h2>Фільм не знайдено</h2>
                <a href="/film" class="btn btn-primary mt-3">Повернутися на головну</a>
            </div>
        <% } %>
    </div>
</body>

</html>