<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Найпопулярніші фільми</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/statistic.css">
</head>

<body>
    <% if (user) { %>
    <div class="container-fluid">
        <% if (statistic?.length > 0) { %>
            <h2>5 найпопулярніших фільмів за сеансами</h2>
            
            <div class="table-responsive">
                <table class="table-hover">
                    <thead>
                        <tr>
                            <th>Назва</th>
                            <th>Оригінальна назва</th>
                            <th class="col-description">Опис</th>
                            <th>Жанр</th>
                            <th>Країна</th>
                            <th>Тривалість</th>
                            <th>Рік</th>
                            <th>Рейтинг</th>
                            <th>Сеанси</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% statistic.forEach(film => { %>
                            <tr>
                                <td style="font-size: 14px;"><strong><%= film.title %></strong></td>
                                <td class="text-muted"><%= film.original_title %></td>
                                <td class="col-description"><%= film.description %></td>
                                <td><%= film.genres %></td>
                                <td><%= film.countries %></td>
                                <td><%= film.duration %> хв.</td>
                                <td><%= film.release_year %></td>
                                <td><span class="badge bg-warning text-dark"><%= film.rating %></span></td>
                                <td><span class="badge bg-primary"><%= film.session_count %></span></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center mt-5"><h2>Таких фільмів немає</h2></div>
        <% } %>
    </div>
    <% } else { %>
        <div class="text-center mt-5"><h2>Доступ заборонено</h2></div>
    <% } %>
</body>
</html>