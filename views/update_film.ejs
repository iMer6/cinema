<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Оновлення фільму</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="font-family: Verdana, Geneva, Tahoma, sans-serif;">
    <div class="container">
        <form>
            <h1 class="text-bg-success p-3">Оновити фільм</h1>
            <h2 style="margin-bottom: 5%;">Інформація про фільм</h2>

            <div class="mb-3">
                <label for="film_id" class="form-label">Ідентифікатор фільму</label>
                <input type="number" class="form-control" id="film_id" value="<%= films.film_id %>" name="film_id" readonly>
            </div>
            
            <div class="mb-3">
                <label for="title" class="form-label">Назва фільму</label>
                <input type="text" class="form-control" id="title" value="<%= films.title %>" name="title" maxlength="255" required>
            </div>
            <div class="mb-3">
                <label for="original_title" class="form-label">Оригінальна назва</label>
                <input type="text" class="form-control" id="original_title" value="<%= films.original_title %>" name="original_title" maxlength="255">
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Опис</label>
                <input type="text" class="form-control" id="description" value="<%= films.description %>" name="description">
            </div>
            <div class="mb-3">
                <label for="genre" class="form-label">Жанр</label>
                <input type="text" class="form-control" id="genre" value="<%= films.genres %>" name="genre" maxlength="100">
            </div>
            <div class="mb-3">
                <label for="country" class="form-label">Країна</label>
                <input type="text" class="form-control" id="country" value="<%= films.countries %>" name="country" maxlength="100">
            </div>
            <div class="mb-3">
                <label for="duration" class="form-label">Тривалість (хвилин)</label>
                <input type="number" class="form-control" id="duration" value="<%= films.duration %>" name="duration" min="0" max="300">
            </div>
            <div class="mb-3">
                <label for="release_year" class="form-label">Рік</label>
                <input type="number" class="form-control" id="release_year" value="<%= films.release_year %>" name="release_year" min="1895" max="2050">
            </div>
            <div class="mb-3">
                <label for="rating" class="form-label">Рейтинг</label>
                <input type="number" class="form-control" id="rating" value="<%= films.rating %>" name="rating" min="0" max="10" step="0.1">
            </div>

            <button type="submit" onclick="makeUpdateRequest(event)" class="mb-3 btn btn-success">Оновити</button>
        </form>
    </div>
    <script>
        function makeRequest(path, method, data) {
            fetch(path, {
                method: method,
                headers: { 'Content-type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => { data.success ? window.location.href = data.redirect : alert(`Unexcpected error: ${data.message}`); })
            .catch((err) => { 
                window.location.href = err.redirect;
                alert("Internal server error");
                console.log(err);
            })
        }
        function makeUpdateRequest() {
            if (event) {event.preventDefault(); }

            const data = {
                film_id: parseInt('<%= films.film_id %>'),
                title: document.getElementById("title").value,
                original_title: document.getElementById("original_title").value,
                description: document.getElementById("description").value,
                genre: document.getElementById("genre").value,
                country: document.getElementById("country").value,
                duration: parseInt(document.getElementById("duration").value),
                release_year: parseInt(document.getElementById("release_year").value),
                rating: parseFloat(document.getElementById("rating").value)
            }
            makeRequest('/film/update', 'PUT', data);
        }
    </script>
</body>
</html>