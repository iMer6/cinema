<!DOCTYPE html>
<html lang="uk">

<head>
    <meta charset="UTF-8">
    <title>Кінотеатр</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/public/css/main.css">
</head>
<body>
    <header>
        <div><strong>Кінотеатр</strong></div>
        <nav><a href="/film">Фільм</a>
            &nbsp; 
            Кінотеатр
            &nbsp; 
            <% if (user) { %>
            <a href="/film/statistic" target="_blank">Найпопулярніші фільми</a>
            &nbsp; 
            <a href="/session/statistic" target="_blank">Сеанси за місяцями</a>
            <% } %>
            <% if (!user) { %>
            &nbsp; 
            <a href="javascript:void(0)" onclick="openAuth()" class="account">
                <i class="bi bi-person-circle"></i> Увійти
            </a>
            <% } else { %>
            &nbsp; 
            <a href="javascript:void(0)" onclick="handleLogout()" class="account">
                Вийти <i class="bi bi-box-arrow-right"></i>
            </a>
            <% } %>
        </nav>
    </header>
    <div class="first_div">
        <h1>Список кінотеатрів</h1>
        <a href="/cinema/add_cinema">
            <% if ([2, 3].includes(user?.role)) { %>
            <button class="add_btn" style="font-size: 20px;">
                <i class="bi bi-plus"></i>
            </button>
            <% } %>
        </a>
        <div class="search-container">
            <input class="search-input" type="text" id="cinemaSearch"   
                   placeholder="Пошук за назвою">
        </div>
    </div>
    <div class="container">
        <table>
            <thead>
                <tr>
                    <th>Назва кінотеатру</th>
                    <th>Адреса кінотеатра</th>
                    <th></th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="data-table">
                <% cinemas.forEach(cinema => { %>
                    <tr>
                        <td><%= cinema.name %></td>
                        <td><%= cinema.city, cinema.street, cinema.building  %></td>
                        <% if ([2].includes(user?.role)) { %>
                        <td>
                            <a href="/cinema/<%= cinema.cinema_id %>" target="_blank">
                                <button type="button" class="custom-info-btn primary_btn">
                                    <i class="bi bi-info-circle"></i>
                                </button>
                            </a>
                        </td>
                        <td>
                            <a href="/cinema/<%= cinema.cinema_id %>/update">
                                <button type="button" class="custom-update-btn">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </a>
                        </td>
                        <td>
                            <button class="custom-delete-btn" type="button"
                                    onclick="makeRequest('/cinema/<%= cinema.cinema_id %>/delete', 'DELETE')">
                                <i class="bi-cart"></i>
                            </button>
                        </td>
                        <% } %>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <div id="authModal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <span class="close-btn" onclick="closeAuth()">&times;</span>
            
            <div id="loginForm">
                <h2>Вхід</h2>
                <input type="email" id="loginEmail" placeholder="Email" class="auth-input">
                <input type="password" id="loginPass" placeholder="Пароль" class="auth-input">
                <button class="custom-info-btn form-btn" onclick="handleLogin()">Увійти</button>
                <p class="form-type-p">
                    Немає акаунта? 
                    <a href="javascript:void(0)" onclick="toggleAuth('register')">Реєстрація</a>
                </p>
            </div>

            <div id="registerForm" style="display: none;">
                <h2>Реєстрація</h2>
                <input type="text" id="regName" placeholder="Ім'я" class="auth-input" required>
                <input type="text" id="regSurname" placeholder="Прізвище" class="auth-input">
                <input type="email" id="regEmail" placeholder="Email" class="auth-input" required>
                <input type="password" id="regPass" placeholder="Пароль" class="auth-input" required>
                <button type="submit" class="add_btn form-btn" onclick="handleRegister()">Створити акаунт</button>
                <p class="form-type-p">
                    Вже є акаунт?
                    <a href="javascript:void(0)" onclick="toggleAuth('login')">Увійти</a>
                </p>
            </div>
        </div>
    </div>
    <script src="/public/js/main.js"></script>
</body>

</html>