<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Додавання фільму</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="font-family: Verdana, Geneva, Tahoma, sans-serif;">
    <div class="container">
        <form action="/film/add_film" method="post">
            <h1 class="text-bg-success p-3">Додати фільм</h1>
            <h2 style="margin-bottom: 2.5%;">Інформація про фільм</h2>
            
            <div class="mb-3">
                <label for="title" class="form-label">Назва фільму</label>
                <input type="text" class="form-control" id="title" 
                    placeholder="Назва фільму" name="title" maxlength="255"
                    required>
            </div>
            <div class="mb-3">
                <label for="original_title" class="form-label">Оригінальна назва</label>
                <input type="text" class="form-control" id="original_title" 
                    placeholder="Оригінальна назва" name="original_title" maxlength="255">
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Опис</label>
                <input type="text" class="form-control" id="description" 
                    placeholder="Опис фільму" name="description">
            </div>
            <div class="mb-3">
                <label for="genre" class="form-label">Жанр</label>
                <input type="text" class="form-control" id="genre" 
                    placeholder="Пригоди, боєвик, фантастика, ..." name="genre" maxlength="100">
            </div>
            <div class="mb-3">
                <label for="country" class="form-label">Країна</label>
                <input type="text" class="form-control" id="original_title" 
                    placeholder="Аргентина, Бразилія, Велика Британія, ..." name="country" maxlength="100">
            </div>
            <div class="mb-3">
                <label for="duration" class="form-label">Тривалість (хвилин)</label>
                <input type="number" class="form-control" id="duration" 
                    placeholder="Тривалість фільму" name="duration" min="0" max="300">
            </div>
            <div class="mb-3">
                <label for="release_year" class="form-label">Рік</label>
                <input type="number" class="form-control" id="release_year" 
                    placeholder="Рік випуску" name="release_year" min="1895" max="2050">
            </div>
            <div class="mb-3">
                <label for="rating" class="form-label">Рейтинг</label>
                <input type="number" class="form-control" id="reting" 
                    placeholder="Рейтинг фільму" name="rating" min="0" max="10" step="0.1">
            </div>

            <button type="submit" class="mb-3 btn btn-success">Додати</button>
        </form>
    </div>
    <script>
        function makeRequest(path, method, ...data) {
            let requestBody = { id: data[0] }
            if (method === "PUT") {
                requestBody.title = data[1]
                requestBody.original_title = data[2]
                requestBody.description = data[3]
                requestBody.genre = data[4]
                requestBody.country = data[5]
                requestBody.duration = data[6]
                requestBody.release_year = data[7]
                requestBody.rating = data[8]
            }

            fetch(path, {
                method: method,
                headers: { 'Content-type': 'application/json'},
                body: JSON.stringify(requestBody)
